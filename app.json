{
  "expo": {
    "name": "MotivAid",
    "slug": "MotivAid",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a6704210-5f1b-4b8a-8a0b-4158c0072ecb",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "motivaid",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.megamindhalimi.MotivAid",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "MotivAid uses the camera for AI-assisted blood loss estimation",
        "NSMicrophoneUsageDescription": "MotivAid uses the microphone for voice-based vital sign entry",
        "NSSpeechRecognitionUsageDescription": "MotivAid uses speech recognition for hands-free vital sign entry"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.megamindhalimi.MotivAid"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-logo-small.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "MotivAid uses the camera for AI-assisted blood loss estimation"
        }
      ],
      "expo-speech-recognition"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a6704210-5f1b-4b8a-8a0b-4158c0072ecb"
      }
    }
  }
}
